{
  "name": "webcure",
  "displayName": "WebCure",
  "description": "Hybrid browser automation extension combining Language Model Tools (VS Code Copilot) with file-bridge (Cursor) and Python script recording.",
  "version": "1.0.0",
  "publisher": "Naveed",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/naveedulislam/webcure.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "browser",
    "automation",
    "testing",
    "playwright",
    "web",
    "cursor",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "languageModelTools": [
      {
        "name": "explorer_navigate",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_navigate",
        "displayName": "Navigate to URL",
        "icon": "$(globe)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Open or navigate the browser page to a specific URL.",
        "modelDescription": "Navigate the shared browser page to an absolute URL. Use this before interacting with a site. Returns the final URL and page title after navigation. Do not use for clicking links on the current page; use click_element instead.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "Absolute URL to open (must start with http or https)."
            },
            "waitUntil": {
              "type": "string",
              "enum": [
                "load",
                "domcontentloaded",
                "networkidle"
              ],
              "default": "load",
              "description": "When to consider navigation finished."
            }
          },
          "required": [
            "url"
          ]
        }
      },
      {
        "name": "explorer_resize",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_resize",
        "displayName": "Resize Window",
        "icon": "$(screen-full)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Resize the browser window to a width and height or make it full screen.",
        "modelDescription": "Resize the shared browser viewport. Use preset=fullscreen or provide width and height in pixels. Returns the new viewport size.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "preset": {
              "type": "string",
              "enum": [
                "fullscreen"
              ],
              "description": "Optional preset for full screen size based on current monitor."
            },
            "width": {
              "type": "number",
              "description": "Viewport width in pixels."
            },
            "height": {
              "type": "number",
              "description": "Viewport height in pixels."
            }
          }
        }
      },
      {
        "name": "explorer_extract",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_extract",
        "displayName": "Extract Content",
        "icon": "$(file-text)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Extract readable text from the current page or from a matching selector.",
        "modelDescription": "Return visible text content from the whole page or a specific selector. Optionally trim and limit length. Use this after navigation and interactions to capture content for reasoning.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "selector": {
              "type": "string",
              "description": "Optional CSS selector to scope extraction."
            },
            "maxLength": {
              "type": "number",
              "description": "Optional maximum length of returned text.",
              "default": 8000
            },
            "trimWhitespace": {
              "type": "boolean",
              "description": "Normalize spaces and line breaks.",
              "default": true
            }
          }
        }
      },
      {
        "name": "explorer_click",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_click",
        "displayName": "Click Element",
        "icon": "$(mouse)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Click an element using ref, text, or selector with optional positional targeting.",
        "modelDescription": "Click on an element. Supports ref from explorer_find/snapshot, or direct text/selector with positional options (toLeftOf, toRightOf, above, below).",
        "inputSchema": {
          "type": "object",
          "properties": {
            "element": {
              "type": "string",
              "description": "Human-readable element description."
            },
            "ref": {
              "type": "string",
              "description": "Element reference from explorer_find or snapshot (e.g., 'e1', 'e2')."
            },
            "text": {
              "type": "string",
              "description": "Find element by visible text (alternative to ref)."
            },
            "selector": {
              "type": "string",
              "description": "Find element by CSS/XPath selector (alternative to ref)."
            },
            "button": {
              "type": "string",
              "enum": [
                "left",
                "right",
                "middle"
              ],
              "default": "left"
            },
            "double": {
              "type": "boolean",
              "default": false
            },
            "toLeftOf": {
              "type": "string",
              "description": "Find element to the left of this text."
            },
            "toRightOf": {
              "type": "string",
              "description": "Find element to the right of this text."
            },
            "above": {
              "type": "string",
              "description": "Find element above this text."
            },
            "below": {
              "type": "string",
              "description": "Find element below this text."
            }
          }
        }
      },
      {
        "name": "explorer_hover",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_hover",
        "displayName": "Hover Element",
        "icon": "$(eye)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Hover over an element using ref, text, or selector with optional positional targeting.",
        "modelDescription": "Hover over an element. Supports ref from explorer_find/snapshot, or direct text/selector with positional options. Use to reveal popovers or menus before clicking.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "element": {
              "type": "string",
              "description": "Human-readable element description."
            },
            "ref": {
              "type": "string",
              "description": "Element reference from explorer_find or snapshot (e.g., 'e1', 'e2')."
            },
            "text": {
              "type": "string",
              "description": "Find element by visible text (alternative to ref)."
            },
            "selector": {
              "type": "string",
              "description": "Find element by CSS/XPath selector (alternative to ref)."
            },
            "toLeftOf": {
              "type": "string",
              "description": "Find element to the left of this text."
            },
            "toRightOf": {
              "type": "string",
              "description": "Find element to the right of this text."
            },
            "above": {
              "type": "string",
              "description": "Find element above this text."
            },
            "below": {
              "type": "string",
              "description": "Find element below this text."
            }
          }
        }
      },
      {
        "name": "explorer_type",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_type",
        "displayName": "Type Text",
        "icon": "$(edit)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Type text into an input using ref, text, or selector with optional positional targeting.",
        "modelDescription": "Type text into an input. Supports ref from explorer_find/snapshot, or direct text/selector with positional options (toLeftOf, toRightOf, above, below). Use 'value' parameter for the text to type.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "element": {
              "type": "string",
              "description": "Human-readable element description."
            },
            "ref": {
              "type": "string",
              "description": "Element reference from explorer_find or snapshot (e.g., 'e1', 'e2')."
            },
            "text": {
              "type": "string",
              "description": "Find element by visible text (alternative to ref)."
            },
            "selector": {
              "type": "string",
              "description": "Find element by CSS/XPath selector (alternative to ref)."
            },
            "value": {
              "type": "string",
              "description": "Text to type into the element."
            },
            "submit": {
              "type": "boolean",
              "default": false,
              "description": "Press Enter after typing."
            },
            "slowly": {
              "type": "boolean",
              "default": false,
              "description": "Type one character at a time."
            },
            "toLeftOf": {
              "type": "string",
              "description": "Find element to the left of this text."
            },
            "toRightOf": {
              "type": "string",
              "description": "Find element to the right of this text."
            },
            "above": {
              "type": "string",
              "description": "Find element above this text."
            },
            "below": {
              "type": "string",
              "description": "Find element below this text."
            }
          },
          "required": [
            "value"
          ]
        }
      },
      {
        "name": "explorer_type_from_file",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_type_from_file",
        "displayName": "Type Text from File",
        "icon": "$(file-code)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Type large text content from a file (SQL, JSON, etc.) into an input element.",
        "modelDescription": "Type text from a file into an input. Supports ref from explorer_find, or text/selector with positional options. Use for large content like SQL queries, JSON, or any text file.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "string",
              "description": "Element reference from explorer_find (e.g., 'e1', 'e2')."
            },
            "text": {
              "type": "string",
              "description": "Find element by visible text (alternative to ref)."
            },
            "selector": {
              "type": "string",
              "description": "Find element by CSS selector (alternative to ref)."
            },
            "element": {
              "type": "string",
              "description": "Human-readable element description for confirmation."
            },
            "filePath": {
              "type": "string",
              "description": "Absolute path to file containing text to type."
            },
            "submit": {
              "type": "boolean",
              "default": false,
              "description": "Press Enter after typing."
            },
            "toLeftOf": {
              "type": "string",
              "description": "Find element to the left of this text."
            },
            "toRightOf": {
              "type": "string",
              "description": "Find element to the right of this text."
            },
            "above": {
              "type": "string",
              "description": "Find element above this text."
            },
            "below": {
              "type": "string",
              "description": "Find element below this text."
            }
          },
          "required": [
            "filePath"
          ]
        }
      },
      {
        "name": "explorer_wait_for",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_wait_for",
        "displayName": "Wait For",
        "icon": "$(clock)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Wait for text to appear/disappear or for a given time.",
        "modelDescription": "Wait until a specific text appears or disappears on the page, or wait for a fixed number of seconds. Use to handle loading states.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "time": {
              "type": "number",
              "description": "Seconds to wait."
            },
            "text": {
              "type": "string",
              "description": "Text to wait for."
            },
            "textGone": {
              "type": "string",
              "description": "Text to wait to disappear."
            },
            "timeout": {
              "type": "number",
              "default": 30000,
              "description": "Max wait time in ms."
            }
          }
        }
      },
      {
        "name": "explorer_wait_for_element",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_wait_for_element",
        "displayName": "Wait For Element",
        "icon": "$(watch)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Wait for an element to become visible, hidden, attached, or detached.",
        "modelDescription": "Wait for an element to reach a specific state (visible, hidden, attached, detached). Supports unified targeting: ref, text, or CSS/XPath selector with positional options.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "element": {
              "type": "string",
              "description": "Human-readable element description."
            },
            "ref": {
              "type": "string",
              "description": "Element reference from explorer_find or snapshot."
            },
            "text": {
              "type": "string",
              "description": "Find element by visible text."
            },
            "selector": {
              "type": "string",
              "description": "Find element by CSS/XPath selector."
            },
            "toLeftOf": {
              "type": "string"
            },
            "toRightOf": {
              "type": "string"
            },
            "above": {
              "type": "string"
            },
            "below": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "enum": [
                "visible",
                "hidden",
                "attached",
                "detached"
              ],
              "description": "What state to wait for."
            },
            "timeout": {
              "type": "number",
              "default": 30000,
              "description": "Max wait time in ms."
            }
          },
          "required": [
            "state"
          ]
        }
      },
      {
        "name": "explorer_select_option",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_select_option",
        "displayName": "Select Option",
        "icon": "$(list-selection)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Select an option from a dropdown using ref, text, or selector.",
        "modelDescription": "Select options in a dropdown. Supports ref from explorer_find/snapshot, or direct text/selector with positional options.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "element": {
              "type": "string"
            },
            "ref": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "selector": {
              "type": "string"
            },
            "values": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Values or labels to select."
            },
            "toLeftOf": {
              "type": "string"
            },
            "toRightOf": {
              "type": "string"
            },
            "above": {
              "type": "string"
            },
            "below": {
              "type": "string"
            }
          },
          "required": [
            "values"
          ]
        }
      },
      {
        "name": "explorer_fill_form",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_fill_form",
        "displayName": "Fill Form",
        "icon": "$(symbol-keyword)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Fill multiple form fields using refs from the snapshot.",
        "modelDescription": "Fill many fields at once using refs from explorer_snapshot. Values for checkbox should be 'true'/'false'.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fields": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "textbox",
                      "checkbox",
                      "radio",
                      "combobox"
                    ]
                  },
                  "ref": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "type",
                  "ref",
                  "value"
                ]
              }
            }
          },
          "required": [
            "fields"
          ]
        }
      },
      {
        "name": "explorer_take_screenshot",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_take_screenshot",
        "displayName": "Take Screenshot",
        "icon": "$(device-camera)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Capture a screenshot of the current page or a specific element.",
        "modelDescription": "Save a screenshot to a file. Optionally specify outputPath, or screenshot a specific element using its ref.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "png",
                "jpeg"
              ],
              "default": "png"
            },
            "fullPage": {
              "type": "boolean",
              "default": false
            },
            "element": {
              "type": "string"
            },
            "ref": {
              "type": "string"
            },
            "outputPath": {
              "type": "string",
              "description": "Optional file path to save screenshot."
            }
          }
        }
      },
      {
        "name": "explorer_close",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_close",
        "displayName": "Close Browser",
        "icon": "$(close-all)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Close the current browser page and dispose resources.",
        "modelDescription": "Close the page. Subsequent tools will re-open a new page automatically.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "explorer_console_messages",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_console_messages",
        "displayName": "Get Console Messages",
        "icon": "$(output)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Return recent console messages from the page.",
        "modelDescription": "Returns all console messages since page creation. Filter to only errors if requested.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "onlyErrors": {
              "type": "boolean"
            }
          }
        }
      },
      {
        "name": "explorer_drag",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_drag",
        "displayName": "Drag And Drop",
        "icon": "$(grabber)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Drag from one element to another using refs from the snapshot.",
        "modelDescription": "Perform drag and drop between two elements using their refs from explorer_snapshot.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "startElement": {
              "type": "string"
            },
            "startRef": {
              "type": "string"
            },
            "endElement": {
              "type": "string"
            },
            "endRef": {
              "type": "string"
            }
          },
          "required": [
            "startElement",
            "startRef",
            "endElement",
            "endRef"
          ]
        }
      },
      {
        "name": "explorer_evaluate",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_evaluate",
        "displayName": "Evaluate Script",
        "icon": "$(code)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Evaluate JavaScript in the page context or on an element.",
        "modelDescription": "Evaluate JavaScript expression on page or element. Optionally use ref from explorer_snapshot.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "function": {
              "type": "string",
              "description": "Function expression like (el)=>el.textContent"
            },
            "element": {
              "type": "string"
            },
            "ref": {
              "type": "string"
            }
          },
          "required": [
            "function"
          ]
        }
      },
      {
        "name": "explorer_file_upload",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_file_upload",
        "displayName": "Upload File",
        "icon": "$(cloud-upload)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Upload one or more files via file input or the file chooser.",
        "modelDescription": "Upload files. If selector is omitted, will wait for a file chooser. Paths must be absolute.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "selector": {
              "type": "string"
            },
            "paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      {
        "name": "explorer_handle_dialog",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_handle_dialog",
        "displayName": "Handle Dialog",
        "icon": "$(comment)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Accept or dismiss the most recent alert/confirm/prompt dialog.",
        "modelDescription": "Handle a dialog that is currently open.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "accept": {
              "type": "boolean"
            },
            "promptText": {
              "type": "string"
            }
          },
          "required": [
            "accept"
          ]
        }
      },
      {
        "name": "explorer_navigate_back",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_navigate_back",
        "displayName": "Navigate Back",
        "icon": "$(arrow-left)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Go back to the previous page.",
        "modelDescription": "Go back to the previous page in history.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "explorer_network_requests",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_network_requests",
        "displayName": "Get Network Requests",
        "icon": "$(rss)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Return recent network requests.",
        "modelDescription": "Returns all network requests observed since page creation.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "explorer_press_key",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_press_key",
        "displayName": "Press Key",
        "icon": "$(keyboard)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Press a key on the keyboard.",
        "modelDescription": "Press a key, e.g. Enter, ArrowLeft, a.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string"
            }
          },
          "required": [
            "key"
          ]
        }
      },
      {
        "name": "explorer_snapshot",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_snapshot",
        "displayName": "Accessibility Snapshot",
        "icon": "$(search)",
        "canBeReferencedInPrompt": true,
        "userDescription": "Capture the accessibility tree with element references.",
        "modelDescription": "Capture accessibility snapshot of the current page with element references (refs). Use this first to get refs before interacting with elements.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "explorer_tabs",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_tabs",
        "displayName": "Manage Tabs",
        "icon": "$(multiple-windows)",
        "canBeReferencedInPrompt": true,
        "userDescription": "List, create, close, or select a tab.",
        "modelDescription": "Manage tabs: list, new, close, select. Index is 1-based.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "list",
                "new",
                "close",
                "select"
              ]
            },
            "index": {
              "type": "number"
            }
          },
          "required": [
            "action"
          ]
        }
      },
      {
        "name": "explorer_install",
        "tags": [
          "language-model-tools",
          "webcure"
        ],
        "toolReferenceName": "explorer_install",
        "displayName": "Install Browser",
